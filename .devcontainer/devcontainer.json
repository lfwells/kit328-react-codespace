{
    "name": "KIT328 Codespace",
    "dockerComposeFile": ["../docker-compose.yaml", "../docker-compose.override.yaml"],
    "service": "frontend",
    "workspaceFolder": "/workspace",
    "features": {
        "ghcr.io/devcontainers/features/docker-in-docker:2": {
            "version": "latest",
            "moby": true
        }
    },
    "postCreateCommand": "git config --global filter.lfs.required false && git config --global filter.lfs.smudge false",
    "initializeCommand": "docker network create caddy_network || true"
}