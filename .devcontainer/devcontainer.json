{
    "name": "KIT328 Codespace",
    "dockerComposeFile": "../docker-compose.yaml",
    "service": "frontend",
    "workspaceFolder": "/workspace",
    "features": {
        "ghcr.io/devcontainers/features/docker-in-docker:2": {
            "version": "latest",
            "moby": true
        }
    },
    // This tells Git to ignore ALL push hooks system-wide inside the container
    "containerEnv": {
        "GIT_ALLOW_PROTOCOL": "http:https",
        "GIT_EXEC_PATH": "/usr/libexec/git-core"
    },
    "postCreateCommand": "git config --global core.hooksPath /dev/null",
    //this sets up the docker netwrosk
    "initializeCommand": "docker network create caddy_network || true"
}